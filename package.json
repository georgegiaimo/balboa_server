{
  "name": "default",
  "version": "1.0.0",
  "description": "default template",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "cross-env NODE_ENV=development nodemon",
    "dev:watch": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "lint": "biome lint .",
    "check": "biome check .",
    "format": "biome format . --write",
    "start:tsup": "node -r tsconfig-paths/register dist/server.js",
    "build:tsup": "tsup --config tsup.config.ts"
  },
  "dependencies": {
    "@google/genai": "^1.38.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@sendgrid/mail": "^8.1.6",
    "airtable": "^0.12.2",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "mysql2": "^3.16.2",
    "node-cron": "^4.2.1",
    "pino": "^9.9.0",
    "pino-pretty": "^13.1.1",
    "pino-roll": "^3.1.0",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "tsc-alias": "^1.8.16",
    "tslib": "^2.8.1",
    "tsyringe": "^4.10.0",
    "typescript": "^5.9.2",
    "zod": "^4.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.4",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/hpp": "^0.2.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.10.10",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.0.0",
    "node-gyp": "^11.4.2",
    "nodemon": "^3.1.11",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5"
  }
